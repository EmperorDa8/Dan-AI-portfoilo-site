# ============================================================
# .env — API Keys & Secrets for AI Job Application Agent
# Copy this file to .env and fill in your values.
# NEVER commit .env to git!
# ============================================================

# --- LLM Provider (pick one) ---

# Option A: OpenAI (recommended — use gpt-4o-mini for speed/cost)
OPENAI_API_KEY=sk-your-openai-key-here

# Option B: Google Gemini (free tier available)
# GOOGLE_API_KEY=your-google-api-key-here

# --- Gmail App Password ---
# Get it: myaccount.google.com → Security → 2-Step Verification → App Passwords
# Create one for "Mail" on "Windows Computer"
GMAIL_APP_PASSWORD=your-gmail-app-password-here

# --- Optional: LinkedIn cookies file location ---
# After manual login, export cookies with a browser extension like "Cookie-Editor"
# and save the JSON to this path:
# LINKEDIN_COOKIE_FILE=./linkedin_cookies.json
